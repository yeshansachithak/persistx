{
  "name": "persistx",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "demo-vite"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:order": "yarn workspace @persistx/core build && yarn workspace @persistx/cli build && yarn workspace @persistx/adapter-firestore build && yarn workspace @persistx/validator-zod build && yarn workspace vite-project build",
    "demo": "npm run dev -w vite-project",
    "build": "npm run -ws build",
    "dev": "npm run -ws dev",
    "test": "npm run -ws test",
    "lint": "npm run -ws lint",
    "clean": "npm run -ws clean"
  },
  "devDependencies": {
    "@types/node": "^25.0.3"
  },
  "resolutions": {
    "esbuild": "0.24.2",
    "@esbuild/darwin-x64": "0.24.2"
  },
  "packageManager": "yarn@4.12.0"
}
